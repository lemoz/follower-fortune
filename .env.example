# Paid research providers. Keep values in .env locally and Fly secrets in prod.
TWITTERAPI_KEY=
GLM_API_KEY=
GEMINI_API_KEY=

# Public origin used for canonical URLs, sitemap entries, and social metadata.
PUBLIC_ORIGIN=https://networknetworth.fly.dev

# Optional launch instrumentation. Analytics is loaded only after user consent.
GA_MEASUREMENT_ID=
GOOGLE_SITE_VERIFICATION=

# Operational kill switch for local tests or an incident. When set, new paid
# board builds stay offline while researched/cached boards continue to work.
NWNW_DISABLE_RESEARCH=0
